{
  "name": "edu-live-server",
  "version": "1.0.0",
  "description": "教培直播系统后端服务 - 基于 Node.js + Express + ZEGO",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "pm2:start": "pm2 start ecosystem.config.js --env production",
    "pm2:stop": "pm2 stop edu-live-server",
    "pm2:restart": "pm2 reload ecosystem.config.js --env production",
    "pm2:logs": "pm2 logs edu-live-server",
    "db:sync": "node -e \"require('./models').sequelize.sync({alter:true}).then(()=>console.log('Database synced'))\"",
    "docker:build": "docker build -t edu-live-server .",
    "docker:run": "docker-compose up -d"
  },
  "keywords": [
    "education",
    "live-streaming",
    "zego",
    "wechat-pay",
    "alipay"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "compression": "^1.7.4",
    "dotenv": "^16.3.1",
    "sequelize": "^6.35.2",
    "mysql2": "^3.6.5",
    "redis": "^4.6.11",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "express-rate-limit": "^7.1.5",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "wechatpay-node-v3": "^2.1.0",
    "alipay-sdk": "^4.6.0",
    "ali-oss": "^6.20.0",
    "cos-nodejs-sdk-v5": "^2.12.6",
    "request-promise-native": "^1.0.9",
    "axios": "^1.6.2",
    "moment": "^2.29.4",
    "uuid": "^9.0.1",
    "crypto": "^1.0.1",
    "path": "^0.12.7",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
