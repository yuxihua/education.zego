# ==========================================
# 教培直播系统 - 环境变量配置模板
# 复制为 .env 后填入实际值
# ==========================================

# ===== 基础配置 =====
NODE_ENV=production
PORT=8080
BASE_URL=https://api.yourdomain.com

# ===== MySQL 数据库 =====
DB_HOST=localhost
DB_PORT=3306
DB_NAME=edu_live
DB_USER=root
DB_PASSWORD=YourStrongPassword123!

# ===== Redis =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ===== JWT 认证 =====
JWT_SECRET=edu_live_prod_secret_key_2024_random_string_here
JWT_EXPIRE=7d

# ===== ZEGO 即构直播 =====
ZEGO_APP_ID=1234567890
ZEGO_SERVER_SECRET=your_zego_server_secret_here

# ===== 微信支付 =====
WX_APPID=wx_your_appid_here
WX_SECRET=your_app_secret
WX_MCHID=your_merchant_id
WX_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASCBKcwggSjAgEAAoIBAQC...\n-----END PRIVATE KEY-----
WX_SERIAL_NO=your_serial_no
WX_APIV3_KEY=your_api_v3_key

# ===== 支付宝 =====
ALIPAY_APPID=your_alipay_appid
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA...\n-----END RSA PRIVATE KEY-----
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...\n-----END PUBLIC KEY-----

# ===== 阿里云 OSS =====
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=your_access_key
OSS_ACCESS_KEY_SECRET=your_secret_key
OSS_BUCKET=edu-live-bucket

# ===== 腾讯云 COS（备用） =====
COS_SECRET_ID=your_secret_id
COS_SECRET_KEY=your_secret_key
COS_BUCKET=edu-live-125xxxxxx
COS_REGION=ap-guangzhou

# ===== 日志配置 =====
LOG_LEVEL=info
LOG_DIR=./logs

# ===== 上传配置 =====
UPLOAD_MAX_SIZE=104857600
UPLOAD_DIR=./uploads
